// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Warehouse {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  address   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model PickingSession {
  id        String        @id @default(cuid())
  weekKey   String        
  status    String        @default("PENDING") // PENDING, PROCESSING, COMPLETED
  items     PickingItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model PickingItem {
  id             String         @id @default(cuid())
  session        PickingSession @relation(fields: [sessionId], references: [id])
  sessionId      String
  supermarket    String
  productName    String
  quantity       Int
}

model Log {
  id        String   @id @default(cuid())
  type      String   // IN, OUT, MOVE, ADJUST
  quantity  Int
  message   String?
  createdAt DateTime @default(now())
}
